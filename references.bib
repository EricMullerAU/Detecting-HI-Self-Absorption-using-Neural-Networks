Read\_Status: New
Read\_Status\_Date: 2026-04-16T02:41:58.788Z},
    keywords = {Computer Science - Computer Vision and Pattern Recognition},
}
@inproceedings{kim2024,
    title = {Cold gas formation within an {HI} shell in the {Magellanic} {Bridge} from {GASKAP}-{HI} observations},
    url = {https://ui.adsabs.harvard.edu/abs/2024IAUGA..32P.949K},
    abstract = {We will present a new study that investigates the multi-phase structure of a 9 pc scale HI shell located in the Magellanic Bridge using data from the GASKAP-HI survey. Associated with the H-alpha ring DEM-171, this shell is an ideal laboratory to study the effects of dynamical events such as supernovae or stellar winds from massive stars on the HI gas properties. We decompose the HI emission spectra into multiple Gaussian components using ROHSA, which enables us to map out the cold neutral medium (CNM), lukewarm medium (UNM), and warm neutral medium (WNM) that makes up the shell. The higher CNM gas fraction ({\textasciitilde}50\%) and existence of UNM gas indicate that the HI shell undergoes a phase transition in the ISM, leading to the CNM formation, likely due to the gas compression. Additionally, exisiting star clusters and young stellar objects (YSOs) catalogs support the scenario that the expansion of the HI shell can trigger subsequent star formation within the shell. This analysis illustrates the stellar feedback on the multi-phase cycle and star formation activity within the Magellanic Bridge.},
    urldate = {2026-04-21},
    author = {Kim, Shin-Jeong and McClure-Griffits, Naomi and Marchal, Antoine},
