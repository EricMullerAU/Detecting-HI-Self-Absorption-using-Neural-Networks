    keywords = {ISM: atoms, ISM: clouds, radio continuum: ISM, radio lines: ISM, techniques: interferometric, techniques: spectroscopic, ⛔ No DOI found},
    pages = {223--241},
}
@article{knapp1974,
    title = {Observations of {HI} in dense interstellar dust clouds: {II}. {The} cloud {Khavtassi} 3},
