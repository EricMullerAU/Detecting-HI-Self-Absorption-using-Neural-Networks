    volume = {233},
    issn = {0035-8711},
    url = {https://ui.adsabs.harvard.edu/abs/1988MNRAS.233..781D},
    doi = {10.1093/mnras/233.4.781},
    abstract = {We have observed 21-cm absorption through the disc of M31, using the VLA to study the cool atomic phase of the interstellar medium in this nearby spiral galaxy. We find that the abundance of diffuse clouds with 0.125{\textless}τ{\textless}1 in M31 is no higher than in the solar neighbourhood of the Milky Way. The mean spin temperature, (T\_sp\_){\textgreater}{\textasciitilde}300 K, is similar to or higher than the local value. The fraction of the neutral atomic hydrogen in the cool phase is about 0.25 or less. These results imply that M31 has a mixture of warm and cool interstellar phases similar to that in our vicinity of the Milky Way, which suggests either that the heating and cooling balance occurs in a similar pressure environment, or that whatever dynamical processes determine the mixture of warm and cool gas reach a similar equilibrium in M31 as here. Specifically, the warm neutral medium seems to be a robust phase, with a much larger filling-factor than the cool clouds.},
    urldate = {2026-03-25},
